# Swarm Labs Environment Configuration
# Copy this file to .env and fill in your API keys

# ==========================================
# TRADING MODE
# ==========================================
PAPER_TRADING=true

# ==========================================
# RISK CONFIGURATION
# ==========================================
MAX_POSITION_SIZE_PCT=0.02
MAX_DAILY_LOSS_PCT=0.05
MAX_TOTAL_EXPOSURE=0.20
MAX_LEVERAGE_CRYPTO=5.0
MAX_LEVERAGE_FOREX=20.0
MAX_LEVERAGE_FUTURES=10.0

# ==========================================
# BINANCE
# ==========================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here
BINANCE_TESTNET=true

# ==========================================
# BYBIT
# ==========================================
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET=your_bybit_secret_here
BYBIT_TESTNET=true

# ==========================================
# OANDA
# ==========================================
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_PRACTICE=true

# ==========================================
# INTERACTIVE BROKERS
# ==========================================
IBKR_ACCOUNT_ID=your_ibkr_account_id
IBKR_PORT=7497

# ==========================================
# INFRASTRUCTURE
# ==========================================
DATABASE_URL=postgresql://swarm:swarm@localhost:5432/swarm_labs
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==========================================
# MONITORING
# ==========================================
LOG_LEVEL=INFO
DISCORD_WEBHOOK_URL=

# ==========================================
# SECURITY
# ==========================================
JWT_SECRET=your-secret-key-change-this-in-production
